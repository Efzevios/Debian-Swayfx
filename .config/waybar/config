{
    "layer": "top",
    "output": "DP-1",
    "position": "top",
    "margin-top": 0,
    "margin-left": 48,
    "margin-right": 48,
    "height": 30,
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "clock"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "sort-by-number": true,
        "format": "{icon}",
        "format-icons": {
            "1": "●",
            "2": "●",
            "3": "●",
            "4": "●",
            "5": "●",
            "default": "●",
            "focused": "●",
            "urgent": "●"
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": []
        }
    },
    "sway/window": {
        "all-outputs": true,
        "format": "{app_id}",
        "rewrite": {
            "": "..."
        },
        "max-length": 50,
        "tooltip": false
    },
    "clock": {
        "format": "{:%d/%m | %H:%M}",
        "tooltip-format": "{:%A, %d de %B de %Y}",
        "tooltip": true
    }
}

{
  "positionX": "center",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "overlay",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 0,
  "control-center-margin-bottom": 15,
  "control-center-margin-right": 15,
  "control-center-margin-left": 15,
  "notification-grouping": false,
  "notification-2way-close": true,
  "notification-drop-shadow": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-length": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": false,
  "timeout": 5,
  "timeout-low": 1,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 400,
  "notification-visibility": {
    "antigravity": {
      "override-urgency": "low",
      "app-name": "(?i)antigravity|python3"
    },
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "scripts": {
    "play-sound": {
      "exec": "/home/efzevios/.config/swaync/play_sound.sh",
      "run-on": "receive"
    }
  },
  "widgets": [
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notificações ",
      "clear-all-button": true,
      "button-text": "✕"
    },
    "dnd": {
      "text": "Não Perturbe"
    }
  }
}
